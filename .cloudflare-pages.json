{
  "build": {
    "command": "cd frontend && npm ci --legacy-peer-deps || npm install --legacy-peer-deps && npm run build",
    "output_dir": "frontend/build"
  },
  "environment_variables": {
    "NODE_VERSION": "18.17.0"
  },
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
